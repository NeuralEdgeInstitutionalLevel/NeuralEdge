# NeuralEdge AI Backend Environment Variables
# Copy to .env and fill in real values

# === Application ===
DEBUG=true
ENVIRONMENT=development

# === Database ===
DB_PASSWORD=neuraledge_dev_2026
DATABASE_URL=postgresql+asyncpg://neuraledge:neuraledge_dev_2026@localhost:5432/neuraledge

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Security ===
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your-jwt-secret-key-here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_MASTER_KEY=your-encryption-master-key-here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=your-internal-api-key-here

# === Whop ===
WHOP_API_KEY=your-whop-api-key
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret

# === Telegram ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id

# === Workers ===
WORKERS=4
